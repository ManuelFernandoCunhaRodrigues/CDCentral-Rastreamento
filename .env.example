# Runtime
NODE_ENV=production
PORT=3000
# Hostinger Node.js Web App: use 0.0.0.0 or omit HOST.
# VPS behind Nginx: use 127.0.0.1 and keep the app port closed publicly.
HOST=0.0.0.0
TRUST_PROXY_HEADERS=1
ALLOW_LOCAL_ORIGINS=0
REQUIRE_REQUEST_ORIGIN=1
CONSENT_VERSION=2026-04-28

# Site e CORS
SITE_URL=https://seudominio.com.br
ALLOWED_ORIGINS=https://seudominio.com.br
# Mantenha 0 ate o dominio em SITE_URL resolver publicamente.
ENABLE_CANONICAL_REDIRECT=0

# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
# Use uma chave server-side com permissao de insert na tabela leads.
# Recomendado: service_role ou secret key mantida somente no backend.
# Nao use anon/publishable key com o schema padrao fechado por RLS.
SUPABASE_LEADS_INSERT_KEY=your_server_side_insert_key
SUPABASE_LEADS_TABLE=leads

# Cloudflare Turnstile
# Use REQUIRE_TURNSTILE=1 para falhar fechado quando o widget/secret nao estiverem configurados.
# Use REQUIRE_TURNSTILE=0 temporariamente se o Turnstile ainda nao foi criado.
REQUIRE_TURNSTILE=1
TURNSTILE_SITE_KEY=your_public_turnstile_site_key
TURNSTILE_SECRET_KEY=your_private_turnstile_secret_key

# Rate limit distribuido com Upstash Redis. Recomendado em producao para /api/leads.
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token
# Em producao, /api/leads falha fechado por padrao quando Redis/KV nao estiver configurado.
# Use REQUIRE_EXTERNAL_RATE_LIMIT=0 apenas se aceitar fallback em memoria sem rate limit distribuido.
REQUIRE_EXTERNAL_RATE_LIMIT=1
# Opcional e nao recomendado: so use em producao se houver um unico processo Node
# e voce aceitar rate limit nao distribuido.
ALLOW_MEMORY_RATE_LIMIT_IN_PRODUCTION=0

# A tabela deve aceitar os campos:
# nome, whatsapp, tipo, veiculos, consent_at, consent_version, consent_ip
