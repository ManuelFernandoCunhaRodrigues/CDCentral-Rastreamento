# Runtime
NODE_ENV=production
PORT=3000
# Hostinger Node.js Web App: use 0.0.0.0 or omit HOST.
# VPS behind Nginx: use 127.0.0.1 and keep the app port closed publicly.
HOST=0.0.0.0
TRUST_PROXY_HEADERS=1
ALLOW_LOCAL_ORIGINS=0
REQUIRE_REQUEST_ORIGIN=1
CONSENT_VERSION=2026-04-28

# Site e CORS
SITE_URL=https://cdcentralrastreamento.com.br
ALLOWED_ORIGINS=https://cdcentralrastreamento.com.br
# Mantenha 0 ate o dominio em SITE_URL resolver publicamente.
ENABLE_CANONICAL_REDIRECT=0
# Use uma URL HTTPS que resolva. Enquanto o DNS canonico estiver pendente,
# aponte para o dominio de producao da Vercel.
CSP_REPORT_URL=https://cd-central.vercel.app/api/csp-report

# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
# Use uma chave server-side com permissao de insert na tabela leads.
# Recomendado: service_role ou secret key mantida somente no backend.
# Nao use anon/publishable key com o schema padrao fechado por RLS.
SUPABASE_LEADS_INSERT_KEY=your_server_side_insert_key
SUPABASE_LEADS_TABLE=leads

# Rate limit distribuido com Upstash Redis. Opcional, mas recomendado em producao para /api/leads.
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token
# Use 1 somente se quiser bloquear o formulario quando Upstash nao estiver configurado.
REQUIRE_EXTERNAL_RATE_LIMIT=0
# Mantido por compatibilidade; o fallback em memoria e permitido quando o rate limit externo nao e obrigatorio.
ALLOW_MEMORY_RATE_LIMIT_IN_PRODUCTION=0

# Vercel Cron para expurgo LGPD de leads com mais de 24 meses.
CRON_SECRET=your_random_cron_secret

# A tabela deve aceitar os campos:
# nome, whatsapp, tipo, veiculos, consent_at, consent_version, consent_ip
